{
  "name": "poker-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:extension": "bun build extension/src/background.ts --outfile extension/dist/background.js && bun build extension/src/content.ts --outfile extension/dist/content.js && bun build extension/src/popup.ts --outfile extension/dist/popup.js && bun build extension/src/poker-content.ts --outfile extension/dist/poker-content.js",
    "cards:calibrate": "bun run scripts/calibrate-regions.ts",
    "cards:extract": "bun run scripts/extract-corners.ts",
    "cards:label": "bun run scripts/label-card.ts",
    "cards:status": "bun run scripts/check-references.ts",
    "cards:test": "bun run scripts/test-detection.ts",
    "generate-charts": "bun run scripts/generate-charts.ts",
    "test": "bun test lib/poker/__tests__/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/react": "^3.0.107",
    "ai": "^6.0.105",
    "next": "16.1.6",
    "poker-odds-calculator": "^0.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "chrome-types": "^0.1.420",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
