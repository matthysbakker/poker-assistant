# poker-assistant — environment variables
# Copy to .env.local and fill in values.
# API keys should be loaded from macOS Keychain, not stored here.
# See ~/.claude/rules/secrets-management.md for setup instructions.

# ─── Secrets (store in Keychain, NOT here) ──────────────────────────────────
# ANTHROPIC_API_KEY is loaded from macOS Keychain via ~/.zshrc.
# To set up: security add-generic-password -a "$USER" -s "anthropic-poker-assistant" -w "sk-ant-..."
# ANTHROPIC_API_KEY=  # leave blank — inherited from shell environment

# ─── Feature flags ───────────────────────────────────────────────────────────
# Save full hand records (JSON + screenshot) to data/hands/
SAVE_HANDS=false

# Save raw capture screenshots to test/captures/ (debug only)
SAVE_CAPTURES=false
